# App settings
DEBUG=false

# WhatsApp Cloud API settings
WHATSAPP_VERIFY_TOKEN=your_verify_token_here
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
META_GRAPH_API_VERSION=v21.0

# WhatsApp App Secret for X-Hub-Signature-256 verification (R1)
# Set to true to enable signature verification on incoming webhooks
WHATSAPP_SIGNATURE_VERIFY_ENABLED=false
WHATSAPP_APP_SECRET=

# RabbitMQ WhatsApp Events
# Set to false to disable event publishing (safe default)
WA_EVENTS_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672/
WA_EVENTS_EXCHANGE=wa.events

# CORS settings (R3)
# Use "*" for dev, or comma-separated origins like "https://kta.partaiummat.or.id,https://admin.partaiummat.or.id"
CORS_ALLOW_ORIGINS=*

# Rate limiting (R6)
# Set to true to enable basic in-memory rate limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10